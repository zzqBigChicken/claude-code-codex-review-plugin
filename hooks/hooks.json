{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/codex-handoff-review-session-start.mjs\"",
            "timeout": 30,
            "statusMessage": "Recording Codex review baseline"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/codex-handoff-review-stop.mjs\"",
            "timeout": 900,
            "statusMessage": "Running Codex handoff review"
          }
        ]
      }
    ]
  }
}
